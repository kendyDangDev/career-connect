# API Configuration Examples for Different Scenarios

# For web development (when running expo on localhost:8081)
EXPO_PUBLIC_API_URL=http://localhost:3000

# For iOS Simulator
# EXPO_PUBLIC_API_URL=http://localhost:3000

# For Android Emulator
# EXPO_PUBLIC_API_URL=http://10.0.2.2:3000

# For physical device on same network (replace with your computer's IP)
# EXPO_PUBLIC_API_URL=http://192.168.150.216:3000
# To find your IP on Windows: Run 'ipconfig' and look for IPv4 Address

# Environment
EXPO_PUBLIC_ENV=development

# API Timeout (in milliseconds)
EXPO_PUBLIC_API_TIMEOUT=30000

# Cloudinary Configuration (for CV storage)
# Sign up at https://cloudinary.com to get your credentials
CLOUDINARY_CLOUD_NAME=your_cloud_name
EXPO_PUBLIC_CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
EXPO_PUBLIC_CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret_keep_private
CLOUDINARY_UPLOAD_PRESET=cv_upload_unsigned
EXPO_PUBLIC_CLOUDINARY_UPLOAD_PRESET=cv_upload_unsigned
