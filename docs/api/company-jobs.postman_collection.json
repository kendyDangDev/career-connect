              "raw": "{{baseUrl}}/api/companies/tech-company/jobs?page=1&limit=10",
              "host": ["{{baseUrl}}"],
              "path": ["api", "companies", "tech-company", "jobs"],
              "query": [
                {"key": "page", "value": "1"},
                {"key": "limit", "value": "10"}
              ]
            }
