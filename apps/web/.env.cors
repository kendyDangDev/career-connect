# CORS Configuration for Mobile App Development

# Allowed origins for CORS (comma-separated)
CORS_ALLOWED_ORIGINS=http://localhost:8081,http://localhost:19000,http://localhost:19001,http://192.168.1.*:8081,exp://localhost:8081

# Allow all origins in development (true/false)
CORS_ALLOW_ALL_DEV=true

# Expo development server URLs
EXPO_DEV_URL=http://localhost:8081
EXPO_GO_URL=http://localhost:19000

# For Android emulator
ANDROID_EMULATOR_URL=http://10.0.2.2:3000

# For iOS simulator
IOS_SIMULATOR_URL=http://localhost:3000

# Local network IP (replace with your actual IP)
LOCAL_NETWORK_IP=192.168.0.106
