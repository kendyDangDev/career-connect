{
  "info": {
    "_postman_id": "company-jobs-api-v1",
    "name": "Career Connect - Company Jobs API",
    "description": "API collection for managing and retrieving company job listings",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Get Company Jobs",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Accept",
            "value": "application/json"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/api/companies/:slug/jobs?page=1&limit=10",
          "host": ["{{baseUrl}}"],
          "path": ["api", "companies", ":slug", "jobs"],
          "variable": [
            {
              "key": "slug",
              "value": "tech-company",
              "description": "Company slug or ID"
            }
          ],
          "query": [
            {
              "key": "page",
              "value": "1",
              "description": "Page number (default: 1)"
            },
            {
              "key": "limit",
              "value": "10",
              "description": "Items per page (max: 50, default: 10)"
            },
            {
              "key": "search",
              "value": "",
              "description": "Search in job title",
              "disabled": true
            },
            {
              "key": "jobType",
              "value": "FULL_TIME",
              "description": "Filter by job type: FULL_TIME, PART_TIME, CONTRACT, INTERNSHIP",
              "disabled": true
            },
            {
              "key": "experienceLevel",
              "value": "SENIOR",
              "description": "Filter by experience: ENTRY, MID, SENIOR, LEAD, EXECUTIVE",
              "disabled": true
            },
            {
              "key": "workLocationType",
              "value": "HYBRID",
              "description": "Filter by work location: ONSITE, REMOTE, HYBRID",
              "disabled": true
            },
            {
              "key": "sortBy",
              "value": "publishedAt",
              "description": "Sort by: createdAt, publishedAt, salaryMin, salaryMax, applicationDeadline",
              "disabled": true
            },
            {
              "key": "sortOrder",
              "value": "desc",
              "description": "Sort order: asc, desc",
              "disabled": true
            },
            {
              "key": "includeExpired",
              "value": "false",
              "description": "Include expired jobs (default: false)",
              "disabled": true
            }
          ]
        }
      },
      "response": [
        {
          "name": "Success Response",
          "originalRequest": {
            "method": "GET",
            "header": [],
